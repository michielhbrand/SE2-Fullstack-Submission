{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"],
    "Properties": {
      "ServiceName": "ManagementApi",
      "Environment": "Development"
    }
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=authdb;Username=postgres;Password=postgres"
  },
  "Keycloak": {
    "Authority": "http://localhost:9090/realms/microservices",
    "Audience": "backend-api",
    "ClientId": "management-portal",
    "ClientSecret": "your-client-secret",
    "AdminUsername": "admin",
    "AdminPassword": "admin"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 60
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 1000
      }
    ],
    "EndpointWhitelist": [
      "get:/health"
    ]
  },
  "IpRateLimitPolicies": {
    "IpRules": [
      {
        "Ip": "127.0.0.1",
        "Rules": [
          {
            "Endpoint": "*",
            "Period": "1m",
            "Limit": 200
          }
        ]
      }
    ]
  },
  "ClientRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "EndpointWhitelist": [
      "get:/health"
    ],
    "ClientRules": [
      {
        "ClientId": "default",
        "Rules": [
          {
            "Endpoint": "*",
            "Period": "1m",
            "Limit": 60
          }
        ]
      }
    ]
  },
  "EndpointRateLimits": {
    "AuthEndpoints": [
      {
        "Endpoint": "post:/api/auth/login",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "post:/api/auth/login",
        "Period": "15m",
        "Limit": 10
      },
      {
        "Endpoint": "post:/api/auth/refresh",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "post:/api/auth/logout",
        "Period": "1m",
        "Limit": 20
      }
    ],
    "UserEndpoints": [
      {
        "Endpoint": "get:/api/users*",
        "Period": "1m",
        "Limit": 30
      },
      {
        "Endpoint": "post:/api/users*",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "put:/api/users*",
        "Period": "1m",
        "Limit": 20
      }
    ],
    "OrganizationEndpoints": [
      {
        "Endpoint": "get:/api/organizations*",
        "Period": "1m",
        "Limit": 30
      },
      {
        "Endpoint": "post:/api/organizations*",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "put:/api/organizations*",
        "Period": "1m",
        "Limit": 20
      }
    ]
  }
}
